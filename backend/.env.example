PORT=5000
MONGODB_URI=mongodb://localhost:27017/securechat
JWT_SECRET=change_this_to_a_long_random_secret_in_production
FRONTEND_URL=http://localhost:5173

# Real SMS via Twilio — sign up at twilio.com, get a verified phone number
# When all three are set, OTPs are sent via SMS. Without them, OTP is logged to console (dev mode).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+15005550006
